// file: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- การตั้งค่าระบบ (System Config) ---
model SystemConfig {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
}

// --- ตารางผู้ใช้งาน (Users) ---
model User {
  id            String    @id @default(uuid())
  name          String?   // Display name
  username      String    @unique
  email         String?   // Optional email
  password      String
  image         String?   @db.Text // Profile image URL
  role          String    @default("USER") // USER, MODERATOR, SELLER, ADMIN
  permissions   String?   @db.Text // JSON array of permission strings
  creditBalance Decimal   @default(0.00) @db.Decimal(10, 2)
  pointBalance  Int       @default(0)  // Point balance for rare items
  totalTopup    Decimal   @default(0.00) @db.Decimal(10, 2) // ยอดเติมเงินสะสม (ไม่หักออก)
  lifetimePoints Int      @default(0)  // พอยต์สะสมตลอดชีพ
  
  // Referral System
  referralCode  String?   @unique  // รหัสเชิญชวนของผู้ใช้
  referredById  String?            // ID ของคนที่เชิญมา
  referredBy    User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]    @relation("Referrals")  // รายชื่อคนที่เชิญมา
  
  // Anti-Abuse
  registrationIp String?  @db.VarChar(45)  // IP ที่ใช้สมัคร (IPv4/IPv6)
  
  orders        Order[]
  topups        Topup[]
  sessions      Session[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ตาราง Session (สำหรับ Session Management) ---
model Session {
  id            String    @id @default(uuid())
  token         String    @unique @db.VarChar(255)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  lastActivity  DateTime  @default(now())
  userAgent     String?   @db.Text
  ipAddress     String?   @db.VarChar(45)
  
  createdAt     DateTime  @default(now())
}

// --- ตาราง API Keys (สำหรับ External Access) ---
model ApiKey {
  id            String    @id @default(uuid())
  name          String    // ชื่อ API Key (เช่น "Mobile App", "Partner Integration")
  key           String    @unique @db.VarChar(64) // Hashed API key
  keyPrefix     String    @db.VarChar(8) // First 8 chars for identification
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions   String?   @db.Text // JSON array of allowed permissions
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  
  @@index([keyPrefix])
}

// --- ตาราง Audit Log (บันทึกกิจกรรมสำคัญ) ---
model AuditLog {
  id            String    @id @default(uuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String    // เช่น "LOGIN", "LOGOUT", "CREATE_PRODUCT", "DELETE_USER"
  resource      String?   // เช่น "Product", "User", "Order"
  resourceId    String?   // ID ของ resource ที่ถูกกระทำ
  details       String?   @db.Text // JSON รายละเอียดเพิ่มเติม
  ipAddress     String?   @db.VarChar(45)
  userAgent     String?   @db.Text
  status        String    @default("SUCCESS") // SUCCESS, FAILURE
  
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// --- ตารางสินค้า (Products) ---
model Product {
  id            String    @id @default(uuid())
  name          String                            // ชื่อสินค้า
  description   String?   @db.Text                // รายละเอียดสินค้า
  notes         String?   @db.Text                // หมายเหตุ
  purchaseNotes String?   @db.Text                // หมายเหตุเมื่อสั่งซื้อ (แสดงตอนกดซื้อ)
  
  price         Decimal   @db.Decimal(10, 2)      // ราคาเต็ม
  discountPrice Decimal?  @db.Decimal(10, 2)      // ราคาลด (ราคาสุดท้าย)
  discountType  String?   @default("FIXED")       // ประเภทส่วนลด: FIXED (บาท) หรือ PERCENT (%)
  discountValue Decimal?  @db.Decimal(10, 2)      // มูลค่าส่วนลด
  
  imageUrl      String?   @db.Text                // ลิงก์รูปภาพสินค้า
  category      String                            // หมวดหมู่ (ข้อความ)
  currency      String    @default("THB")         // สกุลเงิน: THB หรือ POINT
  
  // เชื่อมกับ Category Banner (ถ้ามี)
  categoryBannerId String?
  categoryBanner   CategoryBanner? @relation(fields: [categoryBannerId], references: [id], onDelete: SetNull)
  
  purchaseLimit Int       @default(0)             // จำกัดการซื้อต่อบัญชี (0 = ไม่จำกัด)
  
  secretData    String    @db.Text                // ข้อมูลลับ (ID/Password)
  isSold        Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  sortOrder     Int       @default(0)
  
  orderId       String?   @unique
  order         Order?    @relation(fields: [orderId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ตารางคำสั่งซื้อ (Orders) ---
model Order {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  product       Product?
  totalPrice    Decimal   @db.Decimal(10, 2)
  status        String    @default("COMPLETED")
  purchasedAt   DateTime  @default(now())
}

// --- ตารางเติมเงิน (Topups / TopUpRequests) ---
model Topup {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  amount          Decimal   @db.Decimal(10, 2)
  proofImage      String?   @db.Text // Base64 or URL รูปสลิป
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  transactionRef  String?   @unique // EasySlip transaction reference
  senderName      String?   // ชื่อผู้โอน
  senderBank      String?   // ธนาคารผู้โอน
  receiverName    String?   // ชื่อผู้รับ
  receiverBank    String?   // ธนาคารผู้รับ
  createdAt       DateTime  @default(now())
}

// --- ตารางตั้งค่าเว็บไซต์ (Site Settings) ---
model SiteSettings {
  id              String    @id @default(uuid())
  heroTitle       String
  heroDescription String    @db.Text
  announcement    String?   @db.Text
  
  // Banner Images (External URLs)
  bannerImage1    String?   @db.Text
  bannerTitle1    String?
  bannerSubtitle1 String?
  
  bannerImage2    String?   @db.Text
  bannerTitle2    String?
  bannerSubtitle2 String?
  
  bannerImage3    String?   @db.Text
  bannerTitle3    String?
  bannerSubtitle3 String?
  
  // Logo
  logoUrl         String?   @db.Text
  
  // Background Image
  backgroundImage String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// --- ศูนย์ช่วยเหลือ (Help Center) ---
model HelpArticle {
  id            String    @id @default(uuid())
  question      String    @db.Text
  answer        String    @db.Text
  category      String    @default("general")
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ข่าวสารและโปรโมชั่น (News & Promotions) ---
model NewsArticle {
  id            String    @id @default(uuid())
  title         String
  description   String    @db.Text
  imageUrl      String?   @db.Text
  link          String?   // URL สำหรับ "อ่านเพิ่มเติม"
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- โค้ดส่วนลด (Promo Codes) ---
model PromoCode {
  id            String    @id @default(uuid())
  code          String    @unique              // โค้ดที่ลูกค้าใช้ (e.g. "SALE50")
  discountType  String    @default("PERCENTAGE") // PERCENTAGE or FIXED
  discountValue Decimal   @db.Decimal(10, 2)   // ส่วนลด (% หรือ บาท)
  minPurchase   Decimal?  @db.Decimal(10, 2)   // ยอดขั้นต่ำ
  maxDiscount   Decimal?  @db.Decimal(10, 2)   // ส่วนลดสูงสุด (สำหรับ %)
  usageLimit    Int?                           // จำนวนครั้งที่ใช้ได้ (null = ไม่จำกัด)
  usedCount     Int       @default(0)          // จำนวนที่ใช้แล้ว
  startsAt      DateTime  @default(now())      // เริ่มใช้ได้เมื่อ
  expiresAt     DateTime?                      // หมดอายุเมื่อ (null = ไม่หมดอายุ)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ตั้งค่า Footer Widget ---
model FooterWidgetSettings {
  id          String    @id @default(uuid())
  isActive    Boolean   @default(true)  // เปิด/ปิดการแสดงผล
  title       String    @default("เมนูลัด")  // หัวข้อ widget
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- ลิงก์ใน Footer Widget ---
model FooterLink {
  id           String    @id @default(uuid())
  label        String    // ข้อความที่โชว์
  href         String    // ลิงก์ไปที่
  openInNewTab Boolean   @default(false)  // เปิดแท็บใหม่
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// --- แถบนำทางหลัก (Main Navigation) ---
model NavItem {
  id        String   @id @default(uuid())
  label     String   // ชื่อเมนูที่แสดง
  href      String   // เส้นทาง URL
  icon      String?  // ชื่อ icon (optional)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- การตั้งค่าสกุลเงินพิเศษ (Currency Settings) ---
model CurrencySettings {
  id          String   @id @default("default")
  name        String   @default("พอยท์")      // ชื่อที่แสดง
  symbol      String   @default("💎")         // ไอคอน/สัญลักษณ์
  code        String   @default("POINT")      // รหัส (ไม่เปลี่ยน)
  description String?  @db.Text               // คำอธิบาย
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// --- แบนเนอร์หมวดหมู่ (Category Banners) ---
model CategoryBanner {
  id            String   @id @default(uuid())
  name          String                          // ชื่อหมวดหมู่
  imageUrl      String   @db.Text               // รูปภาพแบนเนอร์
  linkUrl       String?                         // ลิงก์ที่คลิกแล้วไป
  minPrice      Decimal? @db.Decimal(10, 2)     // ราคาต่ำสุด (แสดงผล)
  maxPrice      Decimal? @db.Decimal(10, 2)     // ราคาสูงสุด (แสดงผล)
  productCount  Int      @default(0)            // จำนวนสินค้า (แสดงผล)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  
  // Page Placement
  showOnHome     Boolean @default(true)         // แสดงที่หน้าแรก
  showOnProducts Boolean @default(false)        // แสดงที่หน้าสินค้า
  
  // Relations
  products      Product[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}